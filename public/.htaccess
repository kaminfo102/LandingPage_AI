<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Protect configuration file from public access
  RewriteRule ^api/woo-config\.json$ - [F,L]

  # 2. Proxy all /api/ requests to the PHP script
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^api/(.*)$ api/proxy.php?route=$1 [QSA,L]

  # 3. React SPA routing fallback (if it's not a real file or folder, load index.html)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [QSA,L]
</IfModule>
